# DSE Meli Sync Environment Variables

PROJECT_NAME="DSE Meli Sync"
VERSION=1.0.0

# Database Configuration
# For local dev without docker, use localhost. Inside docker-compose, use 'db'
DATABASE_URL="postgresql+asyncpg://postgres:postgres@db:5432/dse_meli_sync"

# Celery & Redis Configuration
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/0"

# Security & Encryption
# AES key used to decrypt the master prompt. Must be 32 bytes encoded in urlsafe base64.
# You can generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROMPT_DECRYPTION_KEY="your-32-byte-base64-key-here="

# Encrypted Master Prompt Payload (generate this by encrypting your prompt text using the key above)
# We will provide a helper script to generate this.
MASTER_PROMPT_ENCRYPTED="your-encrypted-master-prompt-hex-or-base64-here"

# Mercado Livre API Credentials
MELI_CLIENT_ID="your-meli-client-id"
MELI_CLIENT_SECRET="your-meli-client-secret"
MELI_WEBHOOK_SIGNATURE_KEY="your-meli-webhook-signature-key-or-token"

# LLM Provider Configuration (gemini, openai, etc.)
LLM_PROVIDER="gemini"
LLM_API_KEY="your-llm-api-key"
LLM_MODEL="gemini-1.5-flash"
